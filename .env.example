# ============================================================
# AIFreeMind Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# All model strings follow LiteLLM conventions:
#   https://docs.litellm.ai/docs/providers
# ============================================================

# --- Primary Chat Model ---
# The model used for conversation. Any LiteLLM-compatible string.
# Examples:
#   gemini/gemini-2.0-flash
#   openai/gpt-4o-mini
#   anthropic/claude-sonnet-4-20250514
#   ollama/llama3
PRIMARY_MODEL=gemini/gemini-3.1-pro-preview

# --- API Keys ---
# Set the key for whichever provider your PRIMARY_MODEL uses.
# LiteLLM reads these automatically by name.
GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Fallback Model (optional) ---
# Used if the primary model fails (network error, rate limit, etc.)
# Leave blank to disable fallback.
FALLBACK_MODEL=ollama/llama3
FALLBACK_API_BASE=http://localhost:11434

# --- Reflection Model (optional) ---
# Model used for the end-of-session "mega-prompt" that extracts
# memories and generates the inbox question.
# Defaults to PRIMARY_MODEL if blank. Can use a cheaper model.
REFLECT_MODEL=

# --- Memory Retrieval Settings ---
# Dual retrieval: recent context + semantically relevant memories
# Recent: most recent N memories regardless of topic (working context)
MEMORY_RECENT_K=25
# Relevant: semantically similar to the current query (deep recall)
MEMORY_RELEVANT_K=15
# Minimum similarity score (0.0 - 1.0) for relevant memories.
# Higher = stricter, fewer but more relevant results.
MEMORY_RELEVANCE_THRESHOLD=0.7

# --- Checkpoint Settings ---
# How many exchange pairs (user + assistant) between transcript saves.
# Protects against data loss from crashes.
CHECKPOINT_INTERVAL=10
